# ─── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=whatsapp_bot
POSTGRES_USER=wabot
POSTGRES_PASSWORD=change-me-strong-password

# ─── Connector ─────────────────────────────────────────────────────────────────
CONNECTOR_PORT=3002
# Secret shared between connector and n8n for request authentication
CONNECTOR_SECRET=change-me-connector-secret

# ─── n8n (running separately on host port 5678) ─────────────────────────────────
# URL the connector POSTs incoming WhatsApp messages to.
# Create a webhook trigger in n8n and paste the production URL here.
N8N_WEBHOOK_URL=http://host.docker.internal:5678/webhook/whatsapp-message

# ─── Ollama (running natively on host, default port 11434) ─────────────────────
# Used by n8n — in your n8n workflow set Ollama base URL to:
#   http://host.docker.internal:11434
# If that fails, use the n8n_default gateway IP:
#   docker inspect n8n | grep Gateway   → typically 172.19.0.1
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:latest

# ─── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST_PORT=3001
CONFIDENCE_THRESHOLD=0.70
