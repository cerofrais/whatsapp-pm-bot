    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO tasks (\n  group_id, source_message_id, task_text,\n  assignee_raw, due_date, confidence, needs_review\n)\nSELECT\n  g.id,\n  m.id,\n  $task_text${{ $json.task_text }}$task_text$,\n  $assignee${{ $json.assignee }}$assignee$,\n  NULLIF('{{ $json.due_date }}', 'null')::date,\n  {{ $json.confidence }},\n  {{ $json.confidence }} < 0.70\nFROM groups g\nJOIN messages m ON m.wa_message_id = '{{ $('Webhook').item.json.body.wa_message_id }}'\n  AND m.group_id = g.id\nWHERE g.wa_jid = '{{ $('Webhook').item.json.body.group_jid }}'\nRETURNING id;",
        "options": {}
      },
      "id": "87bcac46-e6a2-46a1-a6ec-41cb87e9e926",
      "name": "Write task to Postgres",
      "type": "n8n-nodes-base.postgres",
