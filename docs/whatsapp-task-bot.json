      "id": "2dc0b0c5-2f69-4660-a338-dd8dfe7f822e",
      "name": "Is @mention?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1780,
        160
      ]
    },
    {
      "parameters": {},
      "id": "d6dbfe3c-0bcb-481a-9a6b-94dc9971073a",
      "name": "Stop - Not a mention",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        2000,
        320
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.task_text, t.assignee_raw, t.due_date, t.status\nFROM tasks t\nJOIN groups g ON g.id = t.group_id\nWHERE g.wa_jid = '{{ $('Webhook').item.json.body.group_jid }}'\n  AND t.status IN ('open', 'overdue')\nORDER BY t.due_date ASC NULLS LAST\nLIMIT 20;",
        "options": {}
      },
      "id": "d52b702d-567e-4576-b300-58043fb2474c",
      "name": "Query open tasks for group",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2000,
        40
      ],
      "credentials": {
        "postgres": {
          "id": "REPLACE_WITH_YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres - whatsapp_bot"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const tasks = $input.all().map(t => t.json);\nif (tasks.length === 0) {\n  return [{ json: { text: 'No open tasks for this group.' } }];\n}\nconst lines = tasks.map((t, i) => {\n  const due = t.due_date ? ` — due ${new Date(t.due_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}` : '';\n  const who = t.assignee_raw ? ` (${t.assignee_raw})` : '';\n  return `${i + 1}. ${t.task_text}${who}${due}`;\n});\nreturn [{ json: { text: `Open tasks:\\n${lines.join('\\n')}` } }];"
      },
      "id": "0fdbd250-a0a0-40d5-965f-ee029f3ffe3d",
      "name": "Format reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
