    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO messages (group_id, wa_message_id, sender_jid, sender_name, body, sent_at)\nSELECT\n  g.id,\n  '{{ $json.body.wa_message_id }}',\n  '{{ $json.body.sender_jid }}',\n  '{{ $json.body.sender_name }}',\n  $body_text${{ $json.body.body }}$body_text$,\n  '{{ $json.body.timestamp }}'::timestamptz\nFROM groups g\nWHERE g.wa_jid = '{{ $json.body.group_jid }}'\nON CONFLICT (group_id, wa_message_id) DO NOTHING\nRETURNING id;",
        "options": {}
      },
      "id": "8647bbb4-95a3-4407-b84f-924d2cbd79a1",
