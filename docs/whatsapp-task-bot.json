    {
      "parameters": {},
      "id": "a0aa3054-7063-4bab-aeff-a331714c7b21",
      "name": "Stop - Group not registered",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        900,
        560
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/generate",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gemma4:latest\",\n  \"stream\": false,\n  \"prompt\": \"You are a task extraction assistant. Given a WhatsApp group message, extract task information as JSON.\\n\\nMessage: {{ $('Webhook').item.json.body.body }}\\nSender: {{ $('Webhook').item.json.body.sender_name }}\\nToday's date: {{ $now.toISO() }}\\n\\nRespond ONLY with a JSON object matching this schema — no prose, no markdown:\\n{\\n  \\\"is_task\\\": boolean,\\n  \\\"task_text\\\": string | null,\\n  \\\"assignee\\\": string | null,\\n  \\\"due_date\\\": \\\"YYYY-MM-DD\\\" | null,\\n  \\\"confidence\\\": number\\n}\\n\\nRules:\\n- is_task=true only if there is a clear action item with an implicit or explicit owner\\n- confidence is 0.0–1.0, your certainty that this is a real task\\n- due_date: resolve relative dates (\\\"friday\\\", \\\"next week\\\") to absolute ISO dates\\n- assignee: the person responsible, often the person being asked\\n- If no task: {\\\"is_task\\\": false, \\\"task_text\\\": null, \\\"assignee\\\": null, \\\"due_date\\\": null, \\\"confidence\\\": 0}\"\n}",
        "options": {}
      },
      "id": "b3946744-3a91-4b53-af56-7f28ba69a6a8",
      "name": "Call Ollama - extract task",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        280
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const raw = $input.first().json.response;\n// Gemma sometimes wraps JSON in markdown code blocks\nconst match = raw.match(/```json\\s*([\\s\\S]*?)\\s*```/) || raw.match(/\\{[\\s\\S]*\\}/);\nconst jsonStr = match ? (match[1] || match[0]) : raw;\nreturn [{ json: JSON.parse(jsonStr.trim()) }];"
      },
      "id": "668b4e47-196a-4d97-9273-8fc890e748b1",
      "name": "Parse Ollama response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        280
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "5f644a61-3c5c-452f-8b2b-52649d436728",
              "leftValue": "={{ $json.is_task }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
